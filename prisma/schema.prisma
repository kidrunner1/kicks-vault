datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  role          Role     @default(USER)
  refreshToken  String?  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


enum Role {
  USER
  ADMIN
}
