datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  password     String
  role         Role    @default(USER)
  refreshToken String?

  favorites Favorite[]
  orders    Order[] // ✅ เพิ่มบรรทัดนี้

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Brand {
  id   String  @id @default(uuid())
  name String  @unique
  slug String  @unique
  logo String?

  shoes Shoe[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shoe {
  id String @id @default(uuid())

  name        String
  slug        String    @unique
  description String
  price       Decimal?  @db.Decimal(10, 2)
  releaseDate DateTime?
  featured    Boolean   @default(false)

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  images    ShoeImage[]
  specs     ShoeSpec[]
  favorites Favorite[]

  orderItems OrderItem[] // ✅ เพิ่ม
  sizes      ShoeSize[] // ✅ เพิ่ม

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShoeImage {
  id String @id @default(uuid())

  url String

  order Int @default(0)

  shoeId String
  shoe   Shoe   @relation(fields: [shoeId], references: [id], onDelete: Cascade)
}

model ShoeSpec {
  id String @id @default(uuid())

  label String
  value String

  shoeId String
  shoe   Shoe   @relation(fields: [shoeId], references: [id], onDelete: Cascade)
}

model Favorite {
  id String @id @default(uuid())

  userId String
  shoeId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shoe Shoe @relation(fields: [shoeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, shoeId], name: "userId_shoeId") 
}

model Order {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  total  Decimal     @db.Decimal(10, 2)
  status OrderStatus @default(PENDING)

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id       String   @id @default(uuid())

  orderId  String
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  shoeId   String
  shoe     Shoe     @relation(fields: [shoeId], references: [id])

  size     String?   // ต้องมีบรรทัดนี้

  quantity Int
  price    Decimal  @db.Decimal(10, 2)

  createdAt DateTime @default(now())
}


enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model ShoeSize {
  id String @id @default(uuid())

  size  String
  stock Int

  shoeId String
  shoe   Shoe   @relation(fields: [shoeId], references: [id], onDelete: Cascade)

  @@unique([shoeId, size])
}
